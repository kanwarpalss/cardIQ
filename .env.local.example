# Supabase — from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Used to encrypt per-user Anthropic API keys at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Google OAuth — from Google Cloud Console → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public app URL (http://localhost:3000 in dev, https://yourapp.vercel.app in prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dining tab — used only by scripts/dining-login.ts and the scraper.
# Your auth.users(id) value. Find at: Supabase dashboard → Authentication → Users → your row.
CARDIQ_USER_ID=
